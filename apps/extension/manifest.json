{
  "manifest_version": 3,
  "name": "ResumeTailor",
  "version": "1.0.0",
  "description": "Browser extension for ResumeTailor",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.naukri.com/*",
        "*://*.indeed.com/*",
        "*://*.wellfound.com/*"
      ],
      "js": ["src/content/index.ts"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "alarms",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost/*",
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*",
    "*://*.indeed.com/*",
    "*://*.wellfound.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:5180; object-src 'self'"
  }
}
